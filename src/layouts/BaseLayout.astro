---
import "@fontsource-variable/inter";
import "../styles/global.css";
import Head from "../components/Head.astro";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
  title: string;
  description?: string;
  /** Slug for per-page OG image; forwarded to Head.astro. Omit to use fallback /og-image.png. */
  ogImageSlug?: string;
  /** Accessible alt text for the OG image. */
  ogImageAlt?: string;
}

const { title, description, ogImageSlug, ogImageAlt } = Astro.props;
const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;

// Hash links smooth-scroll on the homepage, but need a "/" prefix on other routes
// so the browser navigates back to the homepage and lands on the anchor.
// Example: on /now, href="/#about" takes you home and scrolls to #about.
const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "";
const hashPrefix = isHome ? "" : "/";
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <Head title={title} description={description} ogImageSlug={ogImageSlug} ogImageAlt={ogImageAlt} />
  </head>
  <body class="bg-base text-text min-h-dvh transition-colors duration-300 ease-in-out">
    <nav aria-label="Main navigation" class="fixed top-0 right-0 left-0 z-50 bg-base/80 backdrop-blur-sm border-b border-border transition-colors duration-300 ease-in-out">
      <div class="max-w-[1100px] mx-auto px-4 md:px-8 lg:px-12 flex items-center justify-between h-14">
        <!-- Left: empty spacer for layout balance -->
        <div class="hidden md:block"></div>

        <!-- Center-right: desktop nav links (hidden on mobile) -->
        <div class="hidden md:flex items-center gap-6">
          <a href={`${hashPrefix}#about`} data-nav-link class="nav-link text-sm font-medium transition-colors duration-200" style="color: var(--color-text-muted);">About</a>
          <a href={`${hashPrefix}#experience`} data-nav-link class="nav-link text-sm font-medium transition-colors duration-200" style="color: var(--color-text-muted);">Experience</a>
          <a href={`${hashPrefix}#projects`} data-nav-link class="nav-link text-sm font-medium transition-colors duration-200" style="color: var(--color-text-muted);">Projects</a>
          <a href={`${hashPrefix}#contact`} data-nav-link class="nav-link text-sm font-medium transition-colors duration-200" style="color: var(--color-text-muted);">Contact</a>
          <a href="/now" data-nav-link class="nav-link text-sm font-medium transition-colors duration-200" style="color: var(--color-text-muted);">Now</a>
        </div>

        <!-- Right: ThemeToggle + hamburger (mobile only) -->
        <div class="flex items-center gap-2">
          <ThemeToggle />
          <button
            id="hamburger-btn"
            class="md:hidden flex items-center justify-center w-11 h-11 rounded-lg transition-colors duration-200"
            aria-label="Open navigation menu"
            aria-expanded="false"
          >
            <svg id="hamburger-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="3" y1="6" x2="21" y2="6"/>
              <line x1="3" y1="12" x2="21" y2="12"/>
              <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
            <svg id="close-icon" class="hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile dropdown menu (hidden by default) per D-07 -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-border" style="background-color: var(--color-base);">
        <div class="max-w-[1100px] mx-auto px-4 py-2">
          <a href={`${hashPrefix}#about`} data-nav-link class="mobile-nav-link block py-3 px-4 text-sm font-medium rounded-lg transition-colors duration-200" style="color: var(--color-text-muted);">About</a>
          <a href={`${hashPrefix}#experience`} data-nav-link class="mobile-nav-link block py-3 px-4 text-sm font-medium rounded-lg transition-colors duration-200" style="color: var(--color-text-muted);">Experience</a>
          <a href={`${hashPrefix}#projects`} data-nav-link class="mobile-nav-link block py-3 px-4 text-sm font-medium rounded-lg transition-colors duration-200" style="color: var(--color-text-muted);">Projects</a>
          <a href={`${hashPrefix}#contact`} data-nav-link class="mobile-nav-link block py-3 px-4 text-sm font-medium rounded-lg transition-colors duration-200" style="color: var(--color-text-muted);">Contact</a>
          <a href="/now" data-nav-link class="mobile-nav-link block py-3 px-4 text-sm font-medium rounded-lg transition-colors duration-200" style="color: var(--color-text-muted);">Now</a>
        </div>
      </div>
    </nav>
    <main class="max-w-[1100px] mx-auto px-4 md:px-8 lg:px-12 pt-20">
      <slot />
    </main>

    <script>
      // Hamburger menu toggle
      const hamburgerBtn = document.getElementById('hamburger-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamburgerIcon = document.getElementById('hamburger-icon');
      const closeIcon = document.getElementById('close-icon');

      hamburgerBtn?.addEventListener('click', () => {
        const isOpen = !mobileMenu?.classList.contains('hidden');
        mobileMenu?.classList.toggle('hidden', isOpen);
        hamburgerIcon?.classList.toggle('hidden', !isOpen);
        closeIcon?.classList.toggle('hidden', isOpen);
        hamburgerBtn.setAttribute('aria-expanded', String(!isOpen));
      });

      // Close mobile menu when a link is clicked
      const mobileLinks = document.querySelectorAll('#mobile-menu a');
      mobileLinks.forEach((link) => {
        link.addEventListener('click', () => {
          mobileMenu?.classList.add('hidden');
          hamburgerIcon?.classList.remove('hidden');
          closeIcon?.classList.add('hidden');
          hamburgerBtn?.setAttribute('aria-expanded', 'false');
        });
      });

      // Smooth scroll for hash anchors only — real routes (e.g. /now) navigate normally.
      // Without this guard, the handler would preventDefault() on /now clicks and the page would not load.
      const allNavLinks = document.querySelectorAll('[data-nav-link]');
      allNavLinks.forEach((link) => {
        link.addEventListener('click', (e) => {
          const href = link.getAttribute('href');
          if (!href || !href.startsWith('#')) return; // let real pages navigate normally
          e.preventDefault();
          const target = document.querySelector(href);
          target?.scrollIntoView({ behavior: 'smooth' });
        });
      });

      // Mark the /now link active when we're on the /now route.
      // Runs once at script load; the IntersectionObserver below only touches section[id] anchors,
      // so it will not overwrite this data-active attribute.
      if (window.location.pathname === '/now' || window.location.pathname === '/now/') {
        const nowLinks = document.querySelectorAll('[data-nav-link][href="/now"]');
        nowLinks.forEach((link) => link.setAttribute('data-active', 'true'));
      }

      // Intersection Observer for active section highlighting (per D-08)
      const sections = document.querySelectorAll('section[id]');
      const navLinks = document.querySelectorAll('[data-nav-link]');

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              navLinks.forEach((navLink) => {
                const href = navLink.getAttribute('href');
                if (href === `#${entry.target.id}`) {
                  navLink.setAttribute('data-active', 'true');
                } else {
                  navLink.removeAttribute('data-active');
                }
              });
            }
          });
        },
        { rootMargin: '-40% 0px -55% 0px', threshold: 0 }
      );

      sections.forEach((section) => observer.observe(section));
    </script>

    {import.meta.env.PROD && cfAnalyticsToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfAnalyticsToken}"}`}
      />
    )}
  </body>
</html>

<style is:global>
  [data-nav-link][data-active="true"] {
    color: var(--color-accent-primary) !important;
  }
  [data-nav-link][data-active="true"].nav-link {
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
  }
  [data-nav-link]:hover {
    color: var(--color-text) !important;
  }
</style>
