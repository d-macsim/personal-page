---
interface Props {
  title: string;
  description?: string;
  /**
   * Optional slug identifying a per-page OG image at /og/<slug>.png.
   * If omitted, falls back to the static /og-image.png.
   * The slug must be present in src/pages/og/[slug].png.ts's allowlist (see Plan 04).
   */
  ogImageSlug?: string;
  /** Accessible alt text for the OG image. Required when ogImageSlug is set. */
  ogImageAlt?: string;
}

const {
  title,
  description = "Dragos Macsim — AI data specialist. Explore my work, experience, and download my CV.",
  ogImageSlug,
  ogImageAlt,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogImagePath = ogImageSlug ? `/og/${ogImageSlug}.png` : "/og-image.png";
const ogImageAbsolute = new URL(ogImagePath, Astro.site).toString();
const ogImageAltText = ogImageAlt ?? "Dragos Macsim — AI Specialist & Product Builder";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Dragos Macsim",
  givenName: "Dragos",
  familyName: "Macsim",
  jobTitle: "AI Data Specialist",
  description: "AI specialist who builds products — data, ML, and shipping.",
  url: Astro.site?.toString(),
  image: new URL("/profile.jpg", Astro.site).toString(),
  email: "mailto:dragosmacsim@protonmail.com",
  sameAs: [
    "https://www.linkedin.com/in/dragosmacsim/",
    "https://github.com/d-macsim",
  ],
  knowsAbout: [
    "Artificial Intelligence",
    "Machine Learning",
    "Data Analysis",
    "Product Development",
    "Python",
    "TypeScript",
  ],
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImageAbsolute} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogImageAltText} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageAbsolute} />
<meta name="twitter:image:alt" content={ogImageAltText} />
<!--
  T-7-01 mitigation: all JSON-LD values are hand-maintained literals in the frontmatter above.
  Never inject Astro.props or other runtime-derived strings into jsonLd without escaping `</` as `<\/`.
-->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
<script is:inline>
  (function() {
    var stored = localStorage.getItem("theme");
    if (stored === "light") {
      document.documentElement.classList.add("light");
      document.documentElement.classList.remove("dark");
    } else if (stored === "dark") {
      document.documentElement.classList.add("dark");
      document.documentElement.classList.remove("light");
    } else {
      var systemLight = window.matchMedia("(prefers-color-scheme: light)").matches;
      if (systemLight) {
        document.documentElement.classList.add("light");
        document.documentElement.classList.remove("dark");
      } else {
        document.documentElement.classList.add("dark");
        document.documentElement.classList.remove("light");
      }
    }
  })();
</script>
