---
import PhotoPlaceholder from "./PhotoPlaceholder.astro";
import HighlightCard from "./HighlightCard.astro";
---

<section id="about" aria-label="About" class="py-16 md:py-24">
  <h2
    class="font-semibold mb-8"
    style={{ fontSize: "var(--font-size-heading)" }}
  >
    About
  </h2>

  <div class="reveal">
    <div class="flex flex-col items-center mb-8">
      <PhotoPlaceholder />
    </div>

    <div
      class="prose mx-auto"
      style={{
        fontSize: "var(--font-size-body)",
        color: "var(--color-text)",
      }}
    >
      <p>
        I'm an AI specialist and product builder with a background spanning
        machine learning, data analysis, and full-stack product development. I
        combine technical depth with product thinking to build things that
        actually work.
      </p>
      <p class="mt-4">
        Currently at Mindrift, I work on AI training data quality — evaluating
        and improving model outputs across reasoning tasks. My projects,
        including mytai, bring AI into everyday decision-making.
      </p>
      <p class="mt-4">
        I hold an MSc in Statistics from Bayes Business School (City, University
        of London) and a BSc in Economics from UCL.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-12 max-w-2xl mx-auto">
      <HighlightCard label="Current Role" value="AI Trainer · Mindrift" />
      <HighlightCard
        label="Education"
        value="MSc Statistics, Bayes / BSc Economics, UCL"
      />
    </div>
  </div>
</section>
