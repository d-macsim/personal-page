---
import PhotoPlaceholder from "./PhotoPlaceholder.astro";
import HighlightCard from "./HighlightCard.astro";
---

<section id="about" aria-label="About" class="py-16 md:py-24">
  <h2
    class="font-semibold mb-8"
    style={{ fontSize: "var(--font-size-heading)" }}
  >
    About
  </h2>

  <div class="reveal">
    <div class="flex flex-col items-center mb-8">
      <PhotoPlaceholder />
    </div>

    <div
      class="prose mx-auto"
      style={{
        fontSize: "var(--font-size-body)",
        color: "var(--color-text)",
      }}
    >
      <p>
        I'm an AI data specialist with experience in web scraping, data
        extraction, and AI model evaluation. I build automated pipelines and
        work at the intersection of data analysis and artificial intelligence.
      </p>
      <p class="mt-4">
        Currently at Mindrift, I build automated web scraping workflows and
        transform raw data into analysis-ready datasets. Previously at Scale AI,
        I benchmarked text-to-image models and developed RAG-based data
        extraction processes.
      </p>
      <p class="mt-4">
        I hold an MSc in Business Analytics from Bayes Business School and a BSc
        in Information Management for Business from UCL.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-12 max-w-2xl mx-auto">
      <HighlightCard label="Current Role" value="AI Specialist · Mindrift" />
      <HighlightCard
        label="Education"
        value="MSc Business Analytics, Bayes / BSc IMB, UCL"
      />
    </div>
  </div>
</section>
