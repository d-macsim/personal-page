---
---

<section
  aria-label="Hero"
  class="relative flex flex-col items-center justify-center min-h-[calc(100dvh-5rem)] text-center px-4"
>
  <!-- Radial indigo glow -->
  <div
    class="absolute inset-0 overflow-hidden pointer-events-none"
    aria-hidden="true"
  >
    <div
      class="glow-pulse absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[60%] h-[40%] rounded-full"
      style="background: radial-gradient(ellipse at center, rgba(99,102,241,0.35) 0%, transparent 70%);"
    />
  </div>

  <!-- Name -->
  <h1
    class="font-bold hero-reveal"
    style="font-size: var(--font-size-display); line-height: 1.1;"
  >
    Dragos Macsim
  </h1>

  <!-- Professional title -->
  <p
    class="mt-4 hero-reveal hero-reveal-delay-1"
    style="font-size: var(--font-size-heading); color: var(--color-text-muted);"
  >
    AI Data Specialist
  </p>

  <!-- Tagline -->
  <p
    class="mt-4 max-w-prose hero-reveal hero-reveal-delay-2"
    style="font-size: var(--font-size-body);"
  >
    Building intelligent tools at the intersection of AI and product thinking.
  </p>

  <!-- CTA buttons -->
  <div class="flex gap-4 mt-8 flex-wrap justify-center hero-reveal hero-reveal-delay-3">
    <a
      href="#projects"
      data-nav-link
      class="hero-cta-primary inline-flex items-center justify-center rounded-md px-6 py-3 font-semibold transition-all duration-150 hover:scale-[1.02] focus-visible:outline-2 focus-visible:outline-offset-2"
      style="font-size: var(--font-size-label); color: #ffffff; background-color: var(--color-accent-primary-solid); min-width: 160px; outline-color: var(--color-accent-primary);"
    >
      View my work
    </a>
    <a
      href="/Dragos Macsim CV 2026.pdf"
      download
      class="hero-cta-ghost inline-flex items-center justify-center rounded-md px-6 py-3 font-semibold transition-all duration-150 hover:scale-[1.02] focus-visible:outline-2 focus-visible:outline-offset-2"
      style="font-size: var(--font-size-label); color: var(--color-accent-secondary); border: 1px solid var(--color-accent-secondary); background-color: transparent; min-width: 160px; outline-color: var(--color-accent-primary);"
    >
      Download CV
    </a>
  </div>

  <!-- Scroll indicator -->
  <div
    class="mt-12 hero-reveal hero-reveal-delay-4"
    role="img"
    aria-label="Scroll to explore"
  >
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      class="opacity-50"
      aria-hidden="true"
    >
      <path d="m6 9 6 6 6-6" />
    </svg>
  </div>
</section>

<style>
  .hero-reveal {
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero-reveal-delay-1 { animation-delay: 0.15s; }
  .hero-reveal-delay-2 { animation-delay: 0.3s; }
  .hero-reveal-delay-3 { animation-delay: 0.45s; }
  .hero-reveal-delay-4 { animation-delay: 0.6s; }

  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-reveal {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  .hero-cta-primary:hover {
    background-color: var(--color-accent-primary-press) !important;
  }

  .hero-cta-ghost:hover {
    background-color: rgba(245, 158, 11, 0.08) !important;
  }
</style>
