---
import type { Role, EducationEntry } from "../data/cv";

interface Props {
  roles: readonly Role[];
  education: readonly EducationEntry[];
}

const { roles, education } = Astro.props;
---

<div class="relative">
  {/* Spine line — desktop only */}
  <div
    class="absolute left-4 top-0 bottom-0 w-px hidden sm:block"
    style="background-color: var(--color-border);"
  />

  {/* Work experience entries */}
  {
    roles.map((role) => (
      <div class="relative pl-0 sm:pl-12 pb-8 sm:pb-12">
        {/* Dot marker — desktop only */}
        <div
          class="absolute left-3 top-2 w-2.5 h-2.5 rounded-full -translate-x-1/2 hidden sm:block"
          style="background-color: var(--color-accent-primary);"
        />

        {/* Date range */}
        <span
          class="text-xs font-semibold uppercase tracking-widest"
          style={`font-size: var(--font-size-label); color: var(--color-text-muted);`}
        >
          {role.dateRange}
        </span>

        {/* Title and company */}
        <h3 class="font-semibold mt-0.5" style="color: var(--color-text);">
          {role.title}
          <span style="color: var(--color-text-muted);" class="font-normal">
            {" "}
            &middot; {role.company}
          </span>
        </h3>

        {/* Achievement bullets */}
        <ul class="mt-2 space-y-1 list-disc list-inside">
          {role.achievements.map((achievement) => (
            <li
              class="text-sm leading-relaxed"
              style="color: var(--color-text-muted);"
            >
              {achievement}
            </li>
          ))}
        </ul>
      </div>
    ))
  }

  {/* Education separator */}
  <div class="relative pl-0 sm:pl-12 mt-8 mb-4">
    <div
      class="text-xs font-semibold uppercase tracking-widest"
      style={`font-size: var(--font-size-label); color: var(--color-text-muted);`}
    >
      Education
    </div>
  </div>

  {/* Education entries */}
  {
    education.map((entry) => (
      <div class="relative pl-0 sm:pl-12 pb-8 sm:pb-12">
        {/* Dot marker — desktop only */}
        <div
          class="absolute left-3 top-2 w-2.5 h-2.5 rounded-full -translate-x-1/2 hidden sm:block"
          style="background-color: var(--color-accent-primary);"
        />

        {/* Date range */}
        <span
          class="text-xs font-semibold uppercase tracking-widest"
          style={`font-size: var(--font-size-label); color: var(--color-text-muted);`}
        >
          {entry.dateRange}
        </span>

        {/* Degree and institution */}
        <h3 class="font-semibold mt-0.5" style="color: var(--color-text);">
          {entry.degree}
          <span style="color: var(--color-text-muted);" class="font-normal">
            {" "}
            &middot; {entry.institution}
          </span>
        </h3>

        {/* Classification detail */}
        <p class="text-sm mt-1" style="color: var(--color-text-muted);">
          {entry.detail}
        </p>

        {/* Modules (if present) */}
        {entry.modules && (
          <p class="text-xs mt-1" style="color: var(--color-text-muted);">
            Modules: {entry.modules.join(", ")}
          </p>
        )}
      </div>
    ))
  }
</div>
