---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<div
  class="p-6 md:p-8 rounded-2xl"
  style="background-color: var(--color-surface); border: 1px solid var(--color-border);"
>
  <div class="flex flex-col md:flex-row gap-8 md:gap-12 items-center md:items-start">
    <!-- Left: Visual placeholder -->
    {project.id === "mytai" ? (
      <div
        class="w-full max-w-[240px] mx-auto md:mx-0 md:flex-shrink-0 md:w-[240px] h-[480px] rounded-[2.5rem] overflow-hidden relative"
        style="border: 2px solid var(--color-border); background: var(--color-surface);"
        aria-label="mytai app preview"
      >
        <div
          class="absolute inset-0"
          aria-hidden="true"
          style="background: radial-gradient(ellipse at 30% 40%, rgba(99,102,241,0.4) 0%, transparent 65%), radial-gradient(ellipse at 70% 70%, rgba(245,158,11,0.25) 0%, transparent 60%);"
        ></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <span
            class="font-bold tracking-tight"
            style="font-size: 2rem; color: var(--color-text);"
          >
            mytai
          </span>
        </div>
      </div>
    ) : (
      <div
        class="w-full max-w-[240px] mx-auto md:mx-0 md:flex-shrink-0 md:w-[240px] h-[240px] rounded-2xl overflow-hidden relative flex items-center justify-center"
        style="border: 2px solid var(--color-border); background: var(--color-surface);"
        aria-label={`${project.title} preview`}
      >
        <div
          class="absolute inset-0"
          aria-hidden="true"
          style="background: radial-gradient(ellipse at 40% 30%, rgba(34,197,94,0.3) 0%, transparent 65%), radial-gradient(ellipse at 60% 70%, rgba(59,130,246,0.25) 0%, transparent 60%);"
        ></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-text-muted);" aria-hidden="true">
            <rect x="2" y="3" width="20" height="14" rx="2" />
            <line x1="8" y1="21" x2="16" y2="21" />
            <line x1="12" y1="17" x2="12" y2="21" />
          </svg>
        </div>
      </div>
    )}

    <!-- Right: Project details -->
    <div class="flex-1">
      <h3 style="font-size: var(--font-size-heading); font-weight: 600;">
        {project.title}
      </h3>
      <p style="color: var(--color-text-muted); font-size: var(--font-size-body);">
        {project.tagline}
      </p>
      <p style="color: var(--color-text); font-size: var(--font-size-body); margin-top: 1rem;">
        {project.description}
      </p>

      <!-- Feature bullets -->
      <ul class="list-disc pl-5 mt-4 space-y-2">
        {
          project.bullets.map((bullet) => (
            <li style="color: var(--color-text); font-size: var(--font-size-body);">
              {bullet}
            </li>
          ))
        }
      </ul>

      <!-- Tech stack badges -->
      <div class="flex flex-wrap gap-2 mt-6">
        {
          project.techStack.map((badge) => (
            <span
              class="px-3 py-1 rounded-full text-sm font-medium"
              style="background-color: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text);"
            >
              {badge.label}
            </span>
          ))
        }
      </div>

      <!-- CTA button (only if project has a URL) -->
      {project.url && (
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class="project-cta inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold transition-colors duration-200 mt-6"
          style="background-color: var(--color-accent-primary); color: white;"
          aria-label={`${project.urlLabel} (opens in new tab)`}
        >
          {project.urlLabel}
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6" />
            <polyline points="15 3 21 3 21 9" />
            <line x1="10" y1="14" x2="21" y2="3" />
          </svg>
        </a>
      )}
    </div>
  </div>
</div>

<style>
  a.project-cta:hover {
    background-color: var(--color-accent-primary-hover) !important;
  }
  a.project-cta:active {
    background-color: var(--color-accent-primary-press) !important;
  }
</style>
