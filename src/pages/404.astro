---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page not found — Dragos Macsim"
  description="The page you are looking for does not exist."
>
  <section aria-label="404 Not Found" class="py-16 md:py-24 text-center">
    <h1
      class="font-bold mb-4"
      style="font-size: var(--font-size-display); line-height: 1.1;"
    >
      Page not found
    </h1>
    <p class="mb-8" style="color: var(--color-text-muted); font-size: var(--font-size-label);">
      The page you are looking for doesn&rsquo;t exist or has been moved.
    </p>
    <a
      href="/"
      class="inline-block px-6 py-3 rounded-lg font-medium transition-colors duration-200"
      style="background-color: var(--color-accent-primary); color: white;"
    >
      Back to home
    </a>
  </section>
</BaseLayout>
