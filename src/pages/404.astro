---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 - Page Not Found | Dragos Macsim">
  <section
    class="flex flex-col items-center justify-center min-h-[60dvh] text-center px-4"
    aria-label="Page not found"
  >
    <p
      class="text-7xl font-bold tracking-tight"
      style="color: var(--color-accent-primary);"
      aria-hidden="true"
    >
      404
    </p>
    <h1 class="mt-4 text-2xl font-semibold">Page not found</h1>
    <p class="mt-2" style="color: var(--color-text-muted);">
      This page doesn't exist — but the rest does.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 px-6 py-3 rounded-lg font-medium transition-colors duration-200"
      style="background-color: var(--color-accent-primary-solid); color: white;"
    >
      Back to home
    </a>
  </section>
</BaseLayout>
